# Browser Use / LLM
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-xxxxxxxxxxxxx

# Yamato (Kuroneko Members)
KURONEKO_LOGIN_ID=your_kuroneko_id
KURONEKO_PASSWORD=your_kuroneko_password

# Sender (used in address book search)
SENDER_NAME=TechRental

# Shipments data
SHIPMENTS_PATH=shipments.json

# Browser
HEADLESS_BROWSER=false
AUTH_STATE_PATH=auth.json

# Shopify (optional - for ship-shopify command)
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxx
SENDER_POSTAL_CODE=000-0000
SENDER_ADDRESS1=
SENDER_ADDRESS2=
SENDER_PHONE=03-0000-0000
DEFAULT_PACKAGE_SIZE=M
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
